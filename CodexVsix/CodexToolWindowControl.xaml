                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource PopupItemHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.72" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PopupSeparatorStyle" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Margin="10,6"
                                Height="1"
                                Background="{StaticResource PanelBorderBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="PopupMutedHeaderTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>

        <DataTemplate x:Key="PopupCheckedItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="{Binding}"
                           TextTrimming="CharacterEllipsis" />
                <Viewbox Grid.Column="1"
                         Width="10"
                         Height="10"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center">
                    <Path Data="{StaticResource CheckIcon}"
                          Fill="{StaticResource TextSecondaryBrush}"
                          Stretch="Uniform" />
                </Viewbox>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RateLimitPopupEntryTemplate">
            <StackPanel>
                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Text="{Binding Title}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Margin="0,2,0,0"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Text="{Binding Detail}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Visibility="Collapsed"
                Margin="8,8,0,8"
                Padding="8,10"
                Width="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource ResponsivePanelWidthConverter}}"
                Background="{StaticResource PanelBrushSoft}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Button Width="32"
                            Height="32"
                            HorizontalAlignment="Left"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="{Binding Localization.HistoryTooltip}"
                            Command="{Binding ToggleHistoryPanelCommand}">
                        <Viewbox Width="14" Height="14">
                            <Path Data="{StaticResource HistoryIcon}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="0"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Viewbox>
                    </Button>
                    <Button Width="32"
                            Height="32"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="{Binding Localization.SettingsTooltip}"
                            Command="{Binding ToggleSettingsPanelCommand}">
                        <Viewbox Width="14" Height="14">
                            <Path Data="{StaticResource SettingsIcon}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,14,0,0"
                      Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Padding="10"
                            Background="Transparent"
                            Visibility="{Binding ShowHistoryPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding Localization.TopicsTitle}" />
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                    <Button Margin="0,0,6,0"
                                            Style="{StaticResource MiniButtonStyle}"
                                            Content="{Binding Localization.NewTopicButton}"
                                            Command="{Binding NewThreadCommand}" />
                                    <Button Width="24"
                                            Height="24"
                                            Padding="0"
                                            Style="{StaticResource IconButtonStyle}"
                                            ToolTip="{Binding Localization.CloseButton}"
                                            Command="{Binding CloseSidebarCommand}">
                                        <Viewbox Width="10" Height="10">
                                            <Path Data="{StaticResource CloseIcon}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </DockPanel>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Threads}"
                                     SelectedItem="{Binding SelectedThread}"
                                     ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Foreground="{StaticResource TextSecondaryBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ToolTip="{Binding Title}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="28" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Margin="0,4,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11"
                                                       Text="{Binding Subtitle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.RowSpan="2"
                                                       Grid.Column="1"
                                                       Margin="12,0,0,0"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Top"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11"
                                                       Text="{Binding UpdatedAtLabel}" />
                                            <Button Grid.RowSpan="2"
                                                    Grid.Column="2"
                                                    Width="22"
                                                    Height="22"
                                                    Margin="6,0,0,0"
                                                    Padding="0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="{Binding DataContext.Localization.DeleteHistoryTooltip, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding DataContext.DeleteThreadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Viewbox Width="9" Height="9">
                                                    <Path Data="{StaticResource TrashIcon}"
                                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          Stretch="Uniform" />
                                                </Viewbox>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="2"
                                        Margin="0,10,0,0"
                                        Orientation="Horizontal">
                                <TextBox Width="186"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Text="{Binding RenameThreadName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding Localization.RenameTopicPlaceholder}" />
                                <Button Margin="8,0,0,0"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Content="{Binding Localization.RenameTopicButton}"
                                        Command="{Binding RenameThreadCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Padding="10"
                            Background="Transparent"
                            Visibility="{Binding ShowSettingsPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,10"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding Localization.SettingsTitle}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.ExecutableLabel}" />
                                <TextBox Margin="0,0,0,10"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Text="{Binding Settings.CodexExecutablePath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.WorkingDirectoryLabel}" />
                                <TextBox Margin="0,0,0,10"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Text="{Binding Settings.WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.CodexConfigLabel}" />
                                <DockPanel Margin="0,0,0,10"
                                           LastChildFill="False">
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding CodexConfigPath}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ChipButtonStyle}"
                                            Content="{Binding Localization.OpenConfigButton}"
                                            Command="{Binding OpenCodexConfigCommand}" />
                                </DockPanel>

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Extension settings" />
                                <DockPanel Margin="0,0,0,10"
                                           LastChildFill="False">
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ExtensionSettingsPath}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ChipButtonStyle}"
                                            Content="Open settings.json"
                                            Command="{Binding OpenExtensionSettingsCommand}" />
                                </DockPanel>

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.CodexSkillsLabel}" />
                                <DockPanel Margin="0,0,0,10"
                                           LastChildFill="False">
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding CodexSkillsDirectory}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ChipButtonStyle}"
                                            Content="{Binding Localization.OpenSkillsFolderButton}"
                                            Command="{Binding OpenCodexSkillsFolderCommand}" />
                                </DockPanel>

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Modelo" />
                                <DockPanel Margin="0,0,0,8"
                                           LastChildFill="False">
                                    <ComboBox MinWidth="180"
                                              Style="{StaticResource PanelComboBoxStyle}"
                                              ItemsSource="{Binding ModelOptions}"
                                              IsTextSearchEnabled="True"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ChipButtonStyle}"
                                            Content="Atualizar modelos"
                                            Command="{Binding RefreshModelsCommand}" />
                                </DockPanel>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Text="{Binding ModelRefreshStatus}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Modelo personalizado" />
                                <DockPanel Margin="0,0,0,10"
                                           LastChildFill="False">
                                    <TextBox MinWidth="180"
                                             Style="{StaticResource PanelTextBoxStyle}"
                                             Text="{Binding CustomModelInput, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ChipButtonStyle}"
                                            Content="Adicionar modelo"
                                            Command="{Binding AddCustomModelCommand}" />
                                </DockPanel>

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.VerbosityLabel}" />
                                <ComboBox Margin="0,0,0,10"
                                          Style="{StaticResource PanelComboBoxStyle}"
                                          ItemsSource="{Binding VerbosityOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedVerbosity, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.ApprovalPolicyLabel}" />
                                <ComboBox Margin="0,0,0,10"
                                          Style="{StaticResource PanelComboBoxStyle}"
                                          ItemsSource="{Binding ApprovalPolicyOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedApprovalPolicy, UpdateSourceTrigger=PropertyChanged}" />

                                <Border Margin="0,4,0,0"
                                        Padding="12"
                                        Background="{StaticResource EventCardBrush}"
                                        BorderBrush="{StaticResource EventCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Localization.ManagedMcpTitle}" />
                                            <Button DockPanel.Dock="Right"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.ManagedMcpApplyButton}"
                                                    Command="{Binding SaveSettingsCommand}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding Localization.ManagedMcpDescription}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding Localization.ManagedMcpHint}"
                                                   TextWrapping="Wrap" />

                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.ManagedMcpAddStdioButton}"
                                                    Command="{Binding AddManagedMcpCommand}"
                                                    CommandParameter="stdio" />
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.ManagedMcpAddUrlButton}"
                                                    Command="{Binding AddManagedMcpCommand}"
                                                    CommandParameter="url" />
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.RefreshStatusButton}"
                                                    Command="{Binding RefreshIntegrationsCommand}" />
                                        </WrapPanel>

                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding Localization.NoManagedMcpServers}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasManagedMcpServers}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <ItemsControl Margin="0,10,0,0"
                                                      ItemsSource="{Binding ManagedMcpServers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="10"
                                                            Background="{StaticResource ChipBrush}"
                                                            BorderBrush="{StaticResource EventCardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <CheckBox VerticalAlignment="Center"
                                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                                          Content="{Binding DataContext.Localization.EnabledLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                <Button DockPanel.Dock="Right"
                                                                        Margin="8,0,0,0"
                                                                        Style="{StaticResource ChipButtonStyle}"
                                                                        Content="{Binding DataContext.Localization.ManagedMcpRemoveButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        Command="{Binding DataContext.RemoveManagedMcpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}" />
                                                            </DockPanel>

                                                            <TextBlock Margin="0,10,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpNameLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                                                            <TextBlock Margin="0,10,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpTransportLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <ComboBox Style="{StaticResource PanelComboBoxStyle}"
                                                                      ItemsSource="{Binding DataContext.McpTransportOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      DisplayMemberPath="Label"
                                                                      SelectedValuePath="Value"
                                                                      SelectedValue="{Binding TransportType, UpdateSourceTrigger=PropertyChanged}" />

                                                            <TextBlock Margin="0,10,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpCommandLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                                     Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />

                                                            <TextBlock Margin="0,10,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpArgsLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                                     MinHeight="64"
                                                                     AcceptsReturn="True"
                                                                     TextWrapping="Wrap"
                                                                     VerticalScrollBarVisibility="Auto"
                                                                     Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" />

                                                            <TextBlock Margin="0,10,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpUrlLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                                     Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0"
                                        Padding="12"
                                        Background="{StaticResource EventCardBrush}"
                                        BorderBrush="{StaticResource EventCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Localization.SkillsTitle}" />
                                            <Button DockPanel.Dock="Right"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.RefreshStatusButton}"
                                                    Command="{Binding RefreshIntegrationsCommand}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding Localization.SkillsDescription}"
                                                   TextWrapping="Wrap" />

                                        <TextBox Margin="0,10,0,0"
                                                 Style="{StaticResource PanelTextBoxStyle}"
                                                 Text="{Binding SkillSearchText, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,10,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.SkillNameLabel}" />
                                        <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                 Text="{Binding NewSkillName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,10,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.SkillDescriptionLabel}" />
                                        <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                 MinHeight="64"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding NewSkillDescription, UpdateSourceTrigger=PropertyChanged}" />

                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.CreateSkillButton}"
                                                    Command="{Binding CreateSkillCommand}" />
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.OpenSkillsFolderButton}"
                                                    Command="{Binding OpenCodexSkillsFolderCommand}" />
                                        </WrapPanel>

                                        <TextBlock Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.InstalledSkillsTitle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding Localization.NoSkillsDetected}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSkills}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <ItemsControl Margin="0,8,0,0"
                                                      ItemsSource="{Binding VisibleSkills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="10"
                                                            Background="{StaticResource ChipBrush}"
                                                            BorderBrush="{StaticResource EventCardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding DisplayTitle}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="11"
                                                                           Text="{Binding Summary}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="10"
                                                                           Text="{Binding ScopeLabel}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1"
                                                                        Margin="12,0,0,0"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Top">
                                                                <CheckBox Margin="0,0,10,0"
                                                                          VerticalAlignment="Center"
                                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                                          Content="{Binding DataContext.Localization.EnabledLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                          IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                          Command="{Binding DataContext.ToggleSkillEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                          CommandParameter="{Binding}" />
                                                                <Button VerticalAlignment="Top"
                                                                        Style="{StaticResource ChipButtonStyle}"
                                                                        Content="{Binding DataContext.Localization.SkillOpenButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding Path}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Margin="0,14,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.RecommendedSkillsTitle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding Localization.NoRecommendedSkills}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRemoteSkills}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <ItemsControl Margin="0,8,0,0"
                                                      ItemsSource="{Binding VisibleRemoteSkills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="10"
                                                            Background="{StaticResource ChipBrush}"
                                                            BorderBrush="{StaticResource EventCardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Name}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="11"
                                                                           Text="{Binding Description}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Margin="12,0,0,0"
                                                                    VerticalAlignment="Top"
                                                                    Style="{StaticResource ChipButtonStyle}"
                                                                    Content="{Binding DataContext.Localization.InstallSkillButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    Command="{Binding DataContext.InstallRemoteSkillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.RawOutputLabel}" />
                                <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                         MinHeight="140"
                                         FontFamily="Consolas"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding Output}" />

                                <TextBlock Margin="0,12,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.AppsTitle}" />
                                <ItemsControl ItemsSource="{Binding Apps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="{Binding Name}" />
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Margin="0,12,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.McpServersTitle}" />
                                <ItemsControl ItemsSource="{Binding McpServers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="{Binding Name}" />
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Text="{Binding AuthStatus}" />
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Text="{Binding ToolsLabel}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid x:Name="MainContentGrid" Grid.Column="1" Margin="14,10,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="TopToolbarHost"
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Orientation="Horizontal">
                <Button x:Name="HistoryToolbarButton"
                        Width="32"
                        Height="28"
                        Margin="0,0,8,0"
                        Style="{StaticResource TopIconButtonStyle}"
                        ToolTip="{Binding Localization.HistoryTooltip}"
                        Command="{Binding ToggleHistoryPanelCommand}">
                    <Viewbox Width="14" Height="14">
                        <Path Data="{StaticResource HistoryIcon}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform" />
                    </Viewbox>
                </Button>

                <Button x:Name="SettingsToolbarButton"
                        Width="32"
                        Height="28"
                        Margin="0,0,8,0"
                        Style="{StaticResource TopIconButtonStyle}"
                        ToolTip="{Binding Localization.SettingsTooltip}"
                        Command="{Binding ToggleSettingsPanelCommand}">
                    <Viewbox Width="14" Height="14">
                        <Path Data="{StaticResource SettingsIcon}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform" />
                    </Viewbox>
                </Button>

                <Button Width="32"
                        Height="28"
                        Style="{StaticResource TopIconButtonStyle}"
                        ToolTip="{Binding Localization.NewTopicButton}"
                        Command="{Binding NewThreadCommand}">
                    <Viewbox Width="14" Height="14">
                        <Path Data="{StaticResource EditIcon}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform" />
                    </Viewbox>
                </Button>
            </StackPanel>

            <Popup PlacementTarget="{Binding ElementName=HistoryToolbarButton}"
                   Placement="Bottom"
                   HorizontalOffset="-4"
                   VerticalOffset="8"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   PopupAnimation="Fade"
                   IsOpen="{Binding ShowHistoryPanel}">
                <Border Width="260"
                        Padding="10"
                        Background="{StaticResource PopupBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="{Binding Localization.TasksTitle}" />

                        <Grid Grid.Row="1"
                              x:Name="HistorySearchPanel"
                              Margin="0,12,0,12"
                              IsVisibleChanged="OnHistorySearchPanelIsVisibleChanged">
                            <Viewbox Width="12"
                                     Height="12"
                                     Margin="0,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     IsHitTestVisible="False">
                                <Path Data="{StaticResource SearchIcon}"
                                      Fill="{StaticResource TextMutedBrush}"
                                      Stretch="Uniform" />
                            </Viewbox>
                            <TextBox x:Name="HistorySearchTextBox"
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                     BorderThickness="0"
                                     CaretBrush="{StaticResource TextPrimaryBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Padding="22,0,0,0"
                                     Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="22,1,0,0"
                                       IsHitTestVisible="False"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="{Binding Localization.HistorySearchPlaceholder}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HistorySearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Grid Grid.Row="2">
                            <TextBlock Margin="4,0,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding Localization.NoTasksDetected}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasVisibleThreads}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ListBox ItemsSource="{Binding VisibleThreads}"
                                     SelectedItem="{Binding SelectedThread}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="{Binding HasVisibleThreads, Converter={StaticResource BoolToVisibilityConverter}}"
                                     ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="12,0,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11"
                                                       Text="{Binding UpdatedAtLabel}" />
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>
            </Popup>

            <Popup PlacementTarget="{Binding ElementName=SettingsToolbarButton}"
                   Placement="Bottom"
                   HorizontalOffset="-24"
                   VerticalOffset="8"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   PopupAnimation="Fade"
                   IsOpen="{Binding ShowSettingsPanel}">
                <Border Width="248"
                        Padding="10"
                        Background="{StaticResource PopupBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel>
                        <Border Padding="12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           Text="{Binding CurrentAccountLabel}"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Margin="0,6,0,0"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Command="{Binding SelectSettingsSectionCommand}"
                                        CommandParameter="account">
                                    <TextBlock Text="{Binding Localization.PersonalAccountLabel}" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,10"
                                Height="1"
                                Background="{StaticResource PanelBorderBrush}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding SelectSettingsSectionCommand}"
                                CommandParameter="codex-menu">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PopupPanelButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCodexMenuExpanded}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                        <Path Data="{StaticResource SettingsIcon}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding Localization.CodexSettingsNav}" />
                                </StackPanel>
                                <Path DockPanel.Dock="Right"
                                      Width="8"
                                      Height="8"
                                      Margin="8,0,0,0"
                                      Data="M 1,1 L 5,5 L 1,9"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.3"
                                      Stretch="Uniform" />
                            </DockPanel>
                        </Button>

                        <StackPanel Margin="12,-2,0,8"
                                    Visibility="{Binding IsCodexMenuExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Margin="0,0,0,6"
                                    Style="{StaticResource MiniButtonStyle}"
                                    HorizontalContentAlignment="Left"
                                    Content="{Binding Localization.OpenAgentSettingsLabel}"
                                    Command="{Binding SelectSettingsSectionCommand}"
                                    CommandParameter="codex" />
                            <Button Margin="0,0,0,6"
                                    Style="{StaticResource MiniButtonStyle}"
                                    HorizontalContentAlignment="Left"
                                    Content="{Binding Localization.ReadDocsLabel}"
                                    Command="{Binding OpenCodexDocsCommand}" />
                            <Button Style="{StaticResource MiniButtonStyle}"
                                    HorizontalContentAlignment="Left"
                                    Content="{Binding Localization.OpenConfigTomlLabel}"
                                    Command="{Binding OpenCodexConfigCommand}" />
                        </StackPanel>

                        <Button Margin="0,0,0,8"
                                Command="{Binding SelectSettingsSectionCommand}"
                                CommandParameter="mcp">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PopupPanelButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMcpSectionSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                        <Path Data="{StaticResource PlugIcon}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding Localization.McpSettingsNav}" />
                                </StackPanel>
                                <Path DockPanel.Dock="Right"
                                      Width="8"
                                      Height="8"
                                      Margin="8,0,0,0"
                                      Data="M 1,1 L 5,5 L 1,9"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.3"
                                      Stretch="Uniform" />
                            </DockPanel>
                        </Button>

                        <Button Margin="0,0,0,8"
                                Command="{Binding SelectSettingsSectionCommand}"
                                CommandParameter="skills">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PopupPanelButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSkillsSectionSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                        <Path Data="{StaticResource BrainIcon}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding Localization.SkillsSettingsNav}" />
                                </StackPanel>
                                <Path DockPanel.Dock="Right"
                                      Width="8"
                                      Height="8"
                                      Margin="8,0,0,0"
                                      Data="M 1,1 L 5,5 L 1,9"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.3"
                                      Stretch="Uniform" />
                            </DockPanel>
                        </Button>

                        <Button Margin="0,0,0,8"
                                Command="{Binding SelectSettingsSectionCommand}"
                                CommandParameter="language">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PopupPanelButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLanguageSectionSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                        <Path Data="{StaticResource GlobeIcon}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding Localization.LanguageNav}" />
                                </StackPanel>
                                <Path DockPanel.Dock="Right"
                                      Width="8"
                                      Height="8"
                                      Margin="8,0,0,0"
                                      Data="M 1,1 L 5,5 L 1,9"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.3"
                                      Stretch="Uniform" />
                            </DockPanel>
                        </Button>

                        <StackPanel x:Name="LanguageOptionsPanel"
                                    Margin="0,0,0,8"
                                    IsVisibleChanged="OnLanguageOptionsPanelIsVisibleChanged"
                                    Visibility="{Binding IsLanguageSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8">
                                <TextBox x:Name="LanguageSearchTextBox"
                                         Background="Transparent"
                                         BorderBrush="Transparent"
                                         BorderThickness="0"
                                         CaretBrush="{StaticResource TextPrimaryBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Padding="0"
                                         Text="{Binding LanguageSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,1,0,0"
                                           IsHitTestVisible="False"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding LanguageSearchPlaceholder}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LanguageSearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <ScrollViewer MaxHeight="220"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding VisibleLanguageOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,0,6"
                                                    Style="{StaticResource PopupPanelButtonStyle}"
                                                    HorizontalContentAlignment="Stretch"
                                                    Tag="{Binding Value}"
                                                    PreviewMouseLeftButtonDown="OnLanguageOptionPreviewMouseLeftButtonDown"
                                                    Click="OnLanguageOptionClick">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                               Text="{Binding Label}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Viewbox Grid.Column="1"
                                                             Width="10"
                                                             Height="10"
                                                             Margin="10,0,0,0">
                                                        <Path Data="{StaticResource CheckIcon}"
                                                              Fill="{StaticResource TextPrimaryBrush}"
                                                              Stretch="Uniform">
                                                            <Path.Visibility>
                                                                <MultiBinding Converter="{StaticResource StringsEqualToVisibilityConverter}">
                                                                    <Binding Path="Value" />
                                                                    <Binding Path="PlacementTarget.DataContext.SelectedLanguageTag" RelativeSource="{RelativeSource AncestorType=Popup}" />
                                                                </MultiBinding>
                                                            </Path.Visibility>
                                                        </Path>
                                                    </Viewbox>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <Button Style="{StaticResource PopupPanelButtonStyle}"
                                Command="{Binding LogOutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                    <Path Data="{StaticResource BanIcon}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                                <TextBlock Text="{Binding Localization.LogOutLabel}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <Grid x:Name="ConversationAreaHost"
                  Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Margin="24,4,32,18">
                    <Border Padding="14,12"
                            Margin="0,0,0,12"
                            Width="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=ActualWidth}"
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource EventCardBrush}"
                            BorderBrush="{StaticResource EventCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="{Binding ShowRecentTasksPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="{Binding Localization.TasksTitle}" />
                                <Button DockPanel.Dock="Right"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="{Binding Localization.CloseButton}"
                                        Command="{Binding DismissRecentTasksPreviewCommand}">
                                    <Viewbox Width="10" Height="10">
                                        <Path Data="{StaticResource CloseIcon}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                </Button>
                            </DockPanel>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding RecentThreadsPreview}"
                                     SelectedItem="{Binding SelectedThread}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                                        <Setter Property="MaxHeight">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource RecentHistoryMaxHeightConverter}">
                                                    <Binding ElementName="MainContentGrid" Path="ActualHeight" />
                                                    <Binding ElementName="PromptComposerBorder" Path="ActualHeight" />
                                                    <Binding ElementName="TopToolbarHost" Path="ActualHeight" />
                                                    <Binding Path="IsRecentTasksPreviewExpanded" />
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecentTasksPreviewExpanded}" Value="True">
                                                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ToolTip="{Binding Title}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="28" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="12,0,0,0"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11"
                                                       Text="{Binding UpdatedAtLabel}" />
                                            <Button Grid.Column="2"
                                                    Width="22"
                                                    Height="22"
                                                    Margin="6,0,0,0"
                                                    Padding="0"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="{Binding DataContext.Localization.DeleteHistoryTooltip, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding DataContext.DeleteThreadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Viewbox Width="9" Height="9">
                                                    <Path Data="{StaticResource TrashIcon}"
                                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          Stretch="Uniform" />
                                                </Viewbox>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Grid.Row="2"
                                    Padding="0"
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Command="{Binding OpenHistoryPanelCommand}"
                                    Visibility="{Binding HasMoreThreadsThanPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding Localization.ViewAllTasksLabel}" />
                            </Button>
                        </Grid>
                    </Border>

                    <Border Padding="14,12"
                            Background="{StaticResource EventCardBrush}"
                            BorderBrush="{StaticResource EventCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="{Binding ShowCodexSetupCard, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="{Binding CodexSetupTitle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Text="{Binding CodexSetupSummary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Margin="12,0,0,0"
                                        Style="{StaticResource ChipButtonStyle}"
                                        Content="{Binding Localization.SetupRefreshButton}"
                                        Command="{Binding RefreshCodexStatusCommand}" />
                            </DockPanel>

                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Text="{Binding CodexSetupDetail}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ShowCodexSetupDetail, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Text="{Binding Localization.SetupExecutableHint}" />
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Text="{Binding CodexSetupExecutablePath}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Text="{Binding Localization.SetupAuthHint}" />
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Text="{Binding CodexSetupAuthenticationLabel}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding ShowCodexSetupVersion, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Text="{Binding Localization.SetupVersionHint}" />
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Text="{Binding CodexSetupVersionLabel}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding NeedsCodexInstall, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Text="{Binding Localization.SetupInstallHint}" />
                                <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                         Margin="0,4,0,0"
                                         FontFamily="Consolas"
                                         IsReadOnly="True"
                                         Text="{Binding CodexSetupInstallCommand, Mode=OneWay}" />
                            </StackPanel>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Margin="0,0,8,8"
                                        Content="{Binding Localization.SetupInstallButton}"
                                        Command="{Binding CopyCodexInstallCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ChipButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NeedsCodexInstall}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,0,8,8"
                                        Content="{Binding Localization.SetupLoginButton}"
                                        Command="{Binding RunCodexLoginCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ChipButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NeedsCodexLogin}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,0,8,8"
                                        Style="{StaticResource ChipButtonStyle}"
                                        Content="{Binding Localization.SetupSettingsButton}"
                                        Command="{Binding ToggleSettingsPanelCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ScrollViewer x:Name="ChatScrollViewer"
                              Grid.Row="1"
                              Grid.Column="0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChatContentHost">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}">
                                    <Border x:Name="Bubble"
                                            MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource ChatBubbleWidthConverter}}"
                                            Margin="8,0,0,26"
                                            Padding="0"
                                            HorizontalAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0">
                                        <StackPanel>
                                            <Grid x:Name="MessageHeaderRow"
                                                  Margin="0,0,0,8"
                                                  HorizontalAlignment="Left"
                                                  Visibility="Collapsed">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="EventTitle"
                                                         Grid.Column="0"
                                                         Tag="ChatSelectable"
                                                         Margin="0,0,8,0"
                                                         Style="{StaticResource ChatMessageTextBoxStyle}"
                                                         Foreground="{StaticResource TextMutedBrush}"
                                                         FontSize="10"
                                                         FontWeight="SemiBold"
                                                         Text="{Binding Title}"
                                                         Loaded="OnChatTextBoxLoaded"
                                                         Unloaded="OnChatTextBoxUnloaded"
                                                         PreviewMouseLeftButtonDown="OnChatTextBoxPreviewMouseLeftButtonDown"
                                                         Visibility="Collapsed" />
                                                <Border x:Name="MarkdownToggleHost"
                                                        Grid.Column="1"
                                                        Visibility="Collapsed"
                                                        Style="{StaticResource ChatToggleHostBorderStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Grid.Column="0"
                                                                Tag="text"
                                                                Margin="0,0,2,0"
                                                                Click="OnSetMarkdownViewClick">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource ChatToggleSegmentButtonStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTextMode}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Text="{Binding DataContext.Localization.MarkdownTextModeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                        </Button>
                                                        <Button Grid.Column="1"
                                                                Tag="rendered"
                                                                Margin="2,0,0,0"
                                                                Click="OnSetMarkdownViewClick">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource ChatToggleSegmentButtonStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRenderedMode}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Text="{Binding DataContext.Localization.MarkdownRenderedModeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                            <DockPanel LastChildFill="False"
                                                       HorizontalAlignment="Left">
                                                <ItemsControl x:Name="UserPromptSkillChips"
                                                              DockPanel.Dock="Left"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Top"
                                                              ItemsSource="{Binding PromptSkillNames}"
                                                              Visibility="Collapsed">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,8,8"
                                                                    Padding="10,6"
                                                                    Background="{StaticResource PopupItemSelectedBrush}"
                                                                    BorderBrush="{StaticResource AccentBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="14">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Viewbox Width="11" Height="11" Margin="0,0,6,0">
                                                                        <Path Data="{StaticResource BoltIcon}"
                                                                              Fill="{StaticResource AccentBrush}"
                                                                              Stretch="Uniform" />
                                                                    </Viewbox>
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               Text="{Binding StringFormat=/{0}}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBox x:Name="BubbleText"
                                                         Tag="ChatSelectable"
                                                         Style="{StaticResource ChatMessageTextBoxStyle}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         FontSize="13"
                                                         HorizontalAlignment="Left"
                                                         MinWidth="24"
                                                         Loaded="OnChatTextBoxLoaded"
                                                         Unloaded="OnChatTextBoxUnloaded"
                                                         PreviewMouseLeftButtonDown="OnChatTextBoxPreviewMouseLeftButtonDown"
                                                         Text="{Binding DisplayText, Mode=OneWay}" />
                                            </DockPanel>
                                            <ui:ChatMarkdownViewer x:Name="MarkdownText"
                                                                   Tag="ChatSelectable"
                                                                   Margin="0"
                                                                   Padding="0"
                                                                   MinWidth="24"
                                                                   HorizontalAlignment="Left"
                                                                   Background="Transparent"
                                                                   BorderThickness="0"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="14"
                                                                   Loaded="OnChatTextBoxLoaded"
                                                                   Unloaded="OnChatTextBoxUnloaded"
                                                                   PreviewMouseLeftButtonDown="OnChatTextBoxPreviewMouseLeftButtonDown"
                                                                   LinkCommand="{Binding DataContext.OpenReferencedPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   WorkspaceRoot="{Binding DataContext.Settings.WorkingDirectory, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   MarkdownText="{Binding Text}"
                                                                   Visibility="Collapsed" />
                                            <Border x:Name="EventDetailHost"
                                                    Margin="0,10,0,0"
                                                    Padding="10,8"
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource EventDetailBrush}"
                                                    BorderBrush="{StaticResource PanelBorderSoftBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Visibility="Collapsed">
                                                <Grid>
                                                    <TextBox x:Name="EventDetailText"
                                                             Tag="ChatSelectable"
                                                             Style="{StaticResource ChatMessageTextBoxStyle}"
                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                             FontFamily="Consolas"
                                                             FontSize="11"
                                                             Loaded="OnChatTextBoxLoaded"
                                                             Unloaded="OnChatTextBoxUnloaded"
                                                             PreviewMouseLeftButtonDown="OnChatTextBoxPreviewMouseLeftButtonDown"
                                                             Text="{Binding Detail}" />
                                                    <ui:ChatMarkdownViewer x:Name="EventDetailMarkdown"
                                                                           Tag="ChatSelectable"
                                                                           Margin="0"
                                                                           Padding="0"
                                                                           Background="Transparent"
                                                                           BorderThickness="0"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="13"
                                                                           Loaded="OnChatTextBoxLoaded"
                                                                           Unloaded="OnChatTextBoxUnloaded"
                                                                           PreviewMouseLeftButtonDown="OnChatTextBoxPreviewMouseLeftButtonDown"
                                                                           LinkCommand="{Binding DataContext.OpenReferencedPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                           WorkspaceRoot="{Binding DataContext.Settings.WorkingDirectory, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                           MarkdownText="{Binding Detail}"
                                                                           Visibility="Collapsed" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasHeader}" Value="True">
                                            <Setter TargetName="MessageHeaderRow" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasTitle}" Value="True">
                                            <Setter TargetName="EventTitle" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CanToggleMarkdownView}" Value="True">
                                            <Setter TargetName="MarkdownToggleHost" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                            <Setter TargetName="EventDetailHost" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ShowMarkdownDetail}" Value="True">
                                            <Setter TargetName="EventDetailText" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="EventDetailMarkdown" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasPromptSkillNames}" Value="True">
                                            <Setter TargetName="UserPromptSkillChips" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasDisplayText}" Value="False">
                                            <Setter TargetName="BubbleText" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ShowMarkdownText}" Value="True">
                                            <Setter TargetName="BubbleText" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="MarkdownText" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                            <Setter TargetName="Bubble" Property="Background" Value="{StaticResource UserBubbleBrush}" />
                                            <Setter TargetName="Bubble" Property="Padding" Value="14,11" />
                                            <Setter TargetName="Bubble" Property="CornerRadius" Value="18" />
                                            <Setter TargetName="Bubble" Property="Margin" Value="0,0,8,26" />
                                            <Setter TargetName="BubbleText" Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsUser}" Value="False">
                                            <Setter TargetName="Bubble" Property="Margin" Value="8,34,0,26" />
                                            <Setter TargetName="BubbleText" Property="FontSize" Value="14" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEvent}" Value="True">
                                            <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Left" />
                                            <Setter TargetName="Bubble" Property="Background" Value="{StaticResource EventCardBrush}" />
                                            <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource EventCardBorderBrush}" />
                                            <Setter TargetName="Bubble" Property="BorderThickness" Value="1" />
                                            <Setter TargetName="Bubble" Property="Padding" Value="14,12" />
                                            <Setter TargetName="Bubble" Property="CornerRadius" Value="14" />
                                            <Setter TargetName="Bubble" Property="Margin" Value="8,4,0,18" />
                                            <Setter TargetName="BubbleText" Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                            <Setter TargetName="BubbleText" Property="FontSize" Value="12" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Margin="34,34,96,26"
                                Padding="14,12"
                                HorizontalAlignment="Left"
                                Background="{StaticResource EventCardBrush}"
                                BorderBrush="{StaticResource EventCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Margin="0,0,6,0"
                                         Fill="{StaticResource TextSecondaryBrush}"
                                         Opacity="0.28">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.18" Value="1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.54" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.9" Value="0.28" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="8"
                                         Height="8"
                                         Margin="0,0,6,0"
                                         Fill="{StaticResource TextSecondaryBrush}"
                                         Opacity="0.28">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.18" Value="0.28" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.36" Value="1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.72" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.9" Value="0.28" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{StaticResource TextSecondaryBrush}"
                                         Opacity="0.28">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.36" Value="0.28" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.54" Value="1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="0.28" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,0,0,8"
                        Padding="10"
                        Background="{StaticResource PanelBrushSoft}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding HasMentionSuggestions, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox ItemsSource="{Binding MentionSuggestions}"
                                 SelectedItem="{Binding SelectedMention}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextSecondaryBrush}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource MiniButtonStyle}"
                                Content="{Binding Localization.InsertButton}"
                                Command="{Binding InsertSelectedMentionCommand}" />
                    </Grid>
                </Border>

                <Border Grid.RowSpan="3"
                        Grid.Column="1"
                        Width="540"
                        Margin="18,0,0,0"
                        Padding="0"
                        Background="{StaticResource PanelBrushSoft}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Margin="16,-1,0,0"
                                Padding="12,9"
                                HorizontalAlignment="Left"
                                Background="{StaticResource WindowBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10,10,0,0">
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                        <Path Data="{StaticResource ClipboardIcon}"
                                              Fill="{StaticResource TextPrimaryBrush}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding SettingsWorkspaceTitle}" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Width="18"
                                        Height="18"
                                        Margin="10,0,0,0"
                                        Padding="0"
                                        Style="{StaticResource TopIconButtonStyle}"
                                        Command="{Binding CloseSettingsDetailCommand}">
                                    <Viewbox Width="9" Height="9">
                                        <Path Data="{StaticResource CloseIcon}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                </Button>
                            </DockPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid Margin="24,22,24,24">
                                <Border Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAccountSectionSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization.AccountTitle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.AccountSubtitle}"
                                                   TextWrapping="Wrap" />
                                        <Border Margin="0,18,0,0"
                                                Padding="14"
                                                Background="{StaticResource ChipBrush}"
                                                BorderBrush="{StaticResource EventCardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Text="{Binding Localization.SignedInAsLabel}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CurrentAccountLabel}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <WrapPanel Margin="0,16,0,0">
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.SetupRefreshButton}"
                                                    Command="{Binding RefreshCodexStatusCommand}" />
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.SetupLoginButton}"
                                                    Command="{Binding RunCodexLoginCommand}" />
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.LogOutAndLogInButton}"
                                                    Command="{Binding LogOutAndLoginCommand}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCodexSectionSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization.CodexSettingsNav}" />
                                        <TextBlock Margin="0,18,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.ExecutableLabel}" />
                                        <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                 Text="{Binding Settings.CodexExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.CodexConfigLabel}" />
                                        <DockPanel LastChildFill="False">
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding CodexConfigPath}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button DockPanel.Dock="Right"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.OpenConfigButton}"
                                                    Command="{Binding OpenCodexConfigCommand}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="Extension settings" />
                                        <DockPanel LastChildFill="False">
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding ExtensionSettingsPath}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button DockPanel.Dock="Right"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="Open settings.json"
                                                    Command="{Binding OpenExtensionSettingsCommand}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="Modelo" />
                                        <DockPanel LastChildFill="False">
                                            <ComboBox MinWidth="180"
                                                      Style="{StaticResource PanelComboBoxStyle}"
                                                      ItemsSource="{Binding ModelOptions}"
                                                      IsTextSearchEnabled="True"
                                                      DisplayMemberPath="Label"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button DockPanel.Dock="Right"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="Atualizar modelos"
                                                    Command="{Binding RefreshModelsCommand}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding ModelRefreshStatus}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="Modelo personalizado" />
                                        <DockPanel LastChildFill="False">
                                            <TextBox MinWidth="180"
                                                     Style="{StaticResource PanelTextBoxStyle}"
                                                     Text="{Binding CustomModelInput, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button DockPanel.Dock="Right"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="Adicionar modelo"
                                                    Command="{Binding AddCustomModelCommand}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.VerbosityLabel}" />
                                        <ComboBox Style="{StaticResource PanelComboBoxStyle}"
                                                  ItemsSource="{Binding VerbosityOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding SelectedVerbosity, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.ApprovalPolicyLabel}" />
                                        <ComboBox Style="{StaticResource PanelComboBoxStyle}"
                                                  ItemsSource="{Binding ApprovalPolicyOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding SelectedApprovalPolicy, UpdateSourceTrigger=PropertyChanged}" />
                                        <WrapPanel Margin="0,16,0,0">
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.ManagedMcpApplyButton}"
                                                    Command="{Binding SaveSettingsCommand}" />
                                            <Button Margin="0,0,8,8"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.ReadDocsLabel}"
                                                    Command="{Binding OpenCodexDocsCommand}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMcpSectionSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="28"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Localization.McpServersTitle}" />
                                            <WrapPanel DockPanel.Dock="Right">
                                                <Button Margin="0,0,8,8"
                                                        Style="{StaticResource ChipButtonStyle}"
                                                        Content="{Binding Localization.ManagedMcpAddStdioButton}"
                                                        Command="{Binding AddManagedMcpCommand}"
                                                        CommandParameter="stdio" />
                                                <Button Margin="0,0,8,8"
                                                        Style="{StaticResource ChipButtonStyle}"
                                                        Content="{Binding Localization.ManagedMcpAddUrlButton}"
                                                        Command="{Binding AddManagedMcpCommand}"
                                                        CommandParameter="url" />
                                                <Button Margin="0,0,8,8"
                                                        Style="{StaticResource ChipButtonStyle}"
                                                        Content="{Binding Localization.ManagedMcpApplyButton}"
                                                        Command="{Binding SaveSettingsCommand}" />
                                            </WrapPanel>
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding Localization.ManagedMcpDescription}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,18,0,8"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization.ManagedMcpTitle}" />
                                        <ItemsControl ItemsSource="{Binding ManagedMcpServers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="12"
                                                            Background="{StaticResource ChipBrush}"
                                                            BorderBrush="{StaticResource EventCardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Name}" />
                                                                <Button DockPanel.Dock="Right"
                                                                        Margin="8,0,0,0"
                                                                        Style="{StaticResource ChipButtonStyle}"
                                                                        Content="{Binding DataContext.Localization.ManagedMcpRemoveButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        Command="{Binding DataContext.RemoveManagedMcpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}" />
                                                            </DockPanel>
                                                            <TextBlock Margin="0,8,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpTransportLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <ComboBox Style="{StaticResource PanelComboBoxStyle}"
                                                                      ItemsSource="{Binding DataContext.McpTransportOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      DisplayMemberPath="Label"
                                                                      SelectedValuePath="Value"
                                                                      SelectedValue="{Binding TransportType, UpdateSourceTrigger=PropertyChanged}" />
                                                            <TextBlock Margin="0,8,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpCommandLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                                     Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />
                                                            <TextBlock Margin="0,8,0,4"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       Text="{Binding DataContext.Localization.ManagedMcpUrlLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                                                     Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization.McpServersTitle}" />
                                        <ItemsControl Margin="0,8,0,0"
                                                      ItemsSource="{Binding McpServers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="12"
                                                            Background="{StaticResource ChipBrush}"
                                                            BorderBrush="{StaticResource EventCardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <StackPanel>
                                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="11"
                                                                       Text="{Binding AuthStatus}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="11"
                                                                       Text="{Binding ToolsLabel}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSkillsSectionSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="28"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Localization.SkillsTitle}" />
                                            <WrapPanel DockPanel.Dock="Right">
                                                <Button Margin="0,0,8,8"
                                                        Style="{StaticResource ChipButtonStyle}"
                                                        Content="{Binding Localization.RefreshStatusButton}"
                                                        Command="{Binding RefreshIntegrationsCommand}" />
                                                <Button Margin="0,0,8,8"
                                                        Style="{StaticResource ChipButtonStyle}"
                                                        Content="{Binding Localization.OpenSkillsFolderButton}"
                                                        Command="{Binding OpenCodexSkillsFolderCommand}" />
                                            </WrapPanel>
                                        </DockPanel>
                                        <TextBox Margin="0,16,0,0"
                                                 Style="{StaticResource PanelTextBoxStyle}"
                                                 Text="{Binding SkillSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,16,0,8"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization.InstalledSkillsTitle}" />
                                        <ItemsControl ItemsSource="{Binding VisibleSkills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="12"
                                                            Background="{StaticResource ChipBrush}"
                                                            BorderBrush="{StaticResource EventCardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding DisplayTitle}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="11"
                                                                           Text="{Binding Summary}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <CheckBox Grid.Column="1"
                                                                      Margin="12,0,0,0"
                                                                      VerticalAlignment="Top"
                                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                                      IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      Command="{Binding DataContext.ToggleSkillEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Margin="0,16,0,8"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization.RecommendedSkillsTitle}" />
                                        <ItemsControl ItemsSource="{Binding VisibleRemoteSkills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="12"
                                                            Background="{StaticResource ChipBrush}"
                                                            BorderBrush="{StaticResource EventCardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Name}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="11"
                                                                           Text="{Binding Description}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Margin="12,0,0,0"
                                                                    Style="{StaticResource ChipButtonStyle}"
                                                                    Content="{Binding DataContext.Localization.InstallSkillButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    Command="{Binding DataContext.InstallRemoteSkillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.RowSpan="3"
                        Margin="22,4,22,10"
                        Panel.ZIndex="40"
                        Padding="14"
                        Background="{StaticResource PopupBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="False"
                                   Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Click="OnOpenHistoryPanelClick"
                                        Command="{Binding OpenHistoryPanelCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ChipButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHistoryViewSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                            <Path Data="{StaticResource HistoryIcon}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding Localization.HistoryNav}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="OnOpenSettingsPanelClick"
                                        Command="{Binding OpenSettingsPanelCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ChipButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSettingsViewSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                            <Path Data="{StaticResource SettingsIcon}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding Localization.SettingsTitle}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Width="30"
                                    Height="30"
                                    Style="{StaticResource TopIconButtonStyle}"
                                    Click="OnCloseSidebarClick"
                                    Command="{Binding CloseSidebarCommand}">
                                <Viewbox Width="10" Height="10">
                                    <Path Data="{StaticResource CloseIcon}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0">
                            <Border Padding="2"
                                    Width="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ActualWidth, Converter={StaticResource ResponsivePanelWidthConverter}}"
                                    Background="Transparent"
                                    Visibility="{Binding ShowHistoryPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization.TasksTitle}" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                            <Button Margin="0,0,8,0"
                                                    Style="{StaticResource ChipButtonStyle}"
                                                    Content="{Binding Localization.NewTopicButton}"
                                                    Command="{Binding NewThreadCommand}" />
                                            <Button Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="{Binding Localization.CloseButton}"
                                                    Command="{Binding CloseSidebarCommand}">
                                                <Viewbox Width="10" Height="10">
                                                    <Path Data="{StaticResource CloseIcon}"
                                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          Stretch="Uniform" />
                                                </Viewbox>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBox Grid.Row="1"
                                             Margin="0,0,0,10"
                                             Style="{StaticResource PanelTextBoxStyle}"
                                             Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}" />

                                    <ListBox Grid.Row="2"
                                             ItemsSource="{Binding VisibleThreads}"
                                             SelectedItem="{Binding SelectedThread}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ToolTip="{Binding Title}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="56" />
                                                        <ColumnDefinition Width="28" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Title}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Row="1"
                                                               Grid.Column="0"
                                                               Margin="0,2,0,0"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="11"
                                                               Text="{Binding Subtitle}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.RowSpan="2"
                                                               Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Top"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="11"
                                                               Text="{Binding UpdatedAtLabel}" />
                                                    <Button Grid.RowSpan="2"
                                                            Grid.Column="2"
                                                            Width="22"
                                                            Height="22"
                                                            Margin="6,0,0,0"
                                                            Padding="0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            ToolTip="{Binding DataContext.Localization.DeleteHistoryTooltip, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            Command="{Binding DataContext.DeleteThreadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Viewbox Width="9" Height="9">
                                                            <Path Data="{StaticResource TrashIcon}"
                                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                  Stretch="Uniform" />
                                                        </Viewbox>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <Grid Visibility="{Binding ShowSettingsPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="10"
                                        Background="{StaticResource EventCardBrush}"
                                        BorderBrush="{StaticResource EventCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <Border Padding="12"
                                                Background="{StaticResource ChipBrush}"
                                                BorderBrush="{StaticResource EventCardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CurrentAccountLabel}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Button Margin="0,8,0,0"
                                                        Padding="0"
                                                        HorizontalAlignment="Left"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        Command="{Binding SelectSettingsSectionCommand}"
                                                        CommandParameter="account">
                                                    <TextBlock Text="{Binding Localization.PersonalAccountLabel}" />
                                                </Button>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Margin="0,12,0,0">
                                            <Button Margin="0,0,0,8"
                                                    Command="{Binding SelectSettingsSectionCommand}"
                                                    CommandParameter="codex-menu">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SettingsNavButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCodexMenuExpanded}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                                            <Path Data="{StaticResource SettingsIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" />
                                                        </Viewbox>
                                                        <TextBlock Text="{Binding Localization.CodexSettingsNav}" />
                                                    </StackPanel>
                                                    <Path DockPanel.Dock="Right" Width="8" Height="8" Margin="8,0,0,0" Data="M 1,1 L 5,5 L 1,9" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.3" Stretch="Uniform" />
                                                </DockPanel>
                                            </Button>
                                            <StackPanel Margin="12,-2,0,8"
                                                        Visibility="{Binding IsCodexMenuExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Button Margin="0,0,0,6" Style="{StaticResource MiniButtonStyle}" HorizontalContentAlignment="Left" Content="{Binding Localization.OpenAgentSettingsLabel}" Command="{Binding SelectSettingsSectionCommand}" CommandParameter="codex" />
                                                <Button Margin="0,0,0,6" Style="{StaticResource MiniButtonStyle}" HorizontalContentAlignment="Left" Content="{Binding Localization.ReadDocsLabel}" Command="{Binding OpenCodexDocsCommand}" />
                                                <Button Style="{StaticResource MiniButtonStyle}" HorizontalContentAlignment="Left" Content="{Binding Localization.OpenConfigTomlLabel}" Command="{Binding OpenCodexConfigCommand}" />
                                            </StackPanel>

