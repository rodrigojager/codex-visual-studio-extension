                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="14,0,32,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFastModeEnabled}" Value="True">
                                                        <Setter Property="Margin" Value="46,0,32,0" />
