                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   IsHitTestVisible="False"
                                                   Text="{Binding SelectedSandboxModeLabel}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Viewbox Width="12"
                                                 Height="12"
                                                 Margin="12,0,0,0"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 IsHitTestVisible="False">
                                            <Path Data="{StaticResource ShieldIcon}"
                                                  Fill="{StaticResource TextSecondaryBrush}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                    </Grid>
                                </Border>
                                <Button Margin="0,0,8,8"
                                        Padding="10,6"
                                        Style="{StaticResource ChipButtonStyle}"
                                        Click="OnMenuButtonClick">
                                    <Button.ContextMenu>
                                        <ContextMenu Style="{StaticResource PopupContextMenuStyle}"
                                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                     Opened="OnRateLimitsContextMenuOpened">
                                            <ContextMenu.Resources>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource PopupMenuItemStyle}" />
                                                <Style TargetType="Separator" BasedOn="{StaticResource PopupSeparatorStyle}" />
                                            </ContextMenu.Resources>
                                            <MenuItem Style="{StaticResource PopupMenuItemStyle}"
                                                      Header="{Binding Localization.ContinueInTitle}"
                                                      HeaderTemplate="{StaticResource PopupMutedHeaderTemplate}"
                                                      IsEnabled="False" />
                                            <MenuItem Style="{StaticResource PopupMenuItemStyle}"
                                                      Header="{Binding Localization.LocalProjectLabel}"
                                                      HeaderTemplate="{StaticResource PopupCheckedItemTemplate}"
                                                      IsEnabled="False" />
                                            <Separator Style="{StaticResource PopupSeparatorStyle}" />
                                            <MenuItem Style="{StaticResource PopupMenuItemStyle}"
                                                      Header="{Binding Localization.RateLimitsTitle}"
                                                      HeaderTemplate="{StaticResource PopupMutedHeaderTemplate}"
                                                      IsEnabled="False" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                            <Path Data="{StaticResource GaugeHighIcon}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding Localization.RateLimitsTitle}" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top">
                                <Border Width="18"
                                        Height="18"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="{StaticResource ChipBrush}"
                                        ToolTip="{Binding ContextWindowDetail}">
                                    <Path Data="{Binding ContextRingGeometry}"
                                          Margin="2"
                                          Stretch="Fill"
                                          Stroke="{StaticResource SuccessBrush}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Border>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10"
                                           Text="{Binding ContextTokensLabel}"
                                           ToolTip="{Binding ContextWindowDetail}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.ColumnSpan="2"
                Panel.ZIndex="40"
                Background="#8C0B0D10"
                Visibility="{Binding HasCurrentApprovalPrompt, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Border Width="460"
                        Padding="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource PopupBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel DataContext="{Binding CurrentApprovalPrompt}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34"
                                    Height="34"
                                    Margin="0,0,12,0"
                                    Background="#26F59E0B"
                                    CornerRadius="17">
                                <Viewbox Margin="9">
                                    <Path Data="{StaticResource WarningIcon}"
                                          Fill="#F59E0B"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Border>
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="{Binding Title}" />
                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"
                                           Text="{Binding Subtitle}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Subtitle, TargetNullValue=''}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ApprovalCommandBlock" Margin="0,16,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Command, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalCommandLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBox Margin="0,4,0,0"
                                     Style="{StaticResource PanelTextBoxStyle}"
                                     FontFamily="Consolas"
                                     IsReadOnly="True"
                                     Text="{Binding Command}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ApprovalReasonBlock" Margin="0,12,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Reason, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalReasonLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding Reason}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ApprovalDirectoryBlock" Margin="0,12,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkingDirectory, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalWorkingDirectoryLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       Text="{Binding WorkingDirectory}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ApprovalGrantRootBlock" Margin="0,12,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GrantRoot, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalGrantRootLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       Text="{Binding GrantRoot}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ItemsControl Margin="0,18,0,0"
                                      ItemsSource="{Binding Options}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,10,10"
                                            Command="{Binding DataContext.ResolveApprovalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ApprovalActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPrimary}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SendButtonBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDanger}" Value="True">
                                                        <Setter Property="Background" Value="#26EF4444" />
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Label}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>

