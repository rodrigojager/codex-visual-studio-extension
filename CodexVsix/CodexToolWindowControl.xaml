        <SolidColorBrush x:Key="WindowBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.ToolWindowBackgroundColorKey}}" />
        <SolidColorBrush x:Key="PanelBrushSoft" Color="{DynamicResource {x:Static themes:EnvironmentColors.ToolWindowBackgroundColorKey}}" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.ToolWindowBorderColorKey}}" />
        <SolidColorBrush x:Key="PanelBorderSoftBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.PanelBorderColorKey}}" />
        <SolidColorBrush x:Key="InputBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.ToolWindowBackgroundColorKey}}" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.PanelBorderColorKey}}" />
        <SolidColorBrush x:Key="ChipBrush" Color="#15FFFFFF" />
        <SolidColorBrush x:Key="PopupBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.CommandBarMenuBackgroundGradientBeginColorKey}}" />
        <SolidColorBrush x:Key="PopupItemHoverBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="PopupItemSelectedBrush" Color="#59FFFFFF" />
        <SolidColorBrush x:Key="SidebarItemHoverBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="SidebarItemSelectedBrush" Color="#59FFFFFF" />
        <SolidColorBrush x:Key="EventCardBrush" Color="#14FFFFFF" />
        <SolidColorBrush x:Key="EventCardBorderBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="EventDetailBrush" Color="#10FFFFFF" />
        <SolidColorBrush x:Key="UserBubbleBrush" Color="#1EFFFFFF" />
        <SolidColorBrush x:Key="SendButtonBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.CommandBarHoverColorKey}}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.ToolWindowTextColorKey}}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.PanelTextColorKey}}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.SystemGrayTextColorKey}}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.PanelHyperlinkColorKey}}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource {x:Static themes:EnvironmentColors.PanelHyperlinkColorKey}}" />

        <Style x:Key="MiniButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="7,5,10,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PopupItemHoverBrush}" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopIconButtonStyle" TargetType="Button" BasedOn="{StaticResource MiniButtonStyle}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.82" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource TopIconButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="Button" BasedOn="{StaticResource MiniButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ChipBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ChipBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource PopupItemHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button" BasedOn="{StaticResource ChipButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="{StaticResource SendButtonBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ApprovalActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ChipButtonStyle}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Background" Value="{StaticResource PopupItemHoverBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="AttachmentRemoveButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="#B3181A20" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="PopupComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="4,2"
                                Padding="12,10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PopupItemHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="10,9">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SidebarItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SidebarItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,0,14,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource PopupComboBoxItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboSurface"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="SelectionContent"
                                                      Margin="0,0,12,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      TextElement.FontSize="{TemplateBinding FontSize}"
                                                      IsHitTestVisible="False" />
                                    <Path Grid.Column="1"
                                          Width="10"
                                          Height="6"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"
                                          Data="M 1,1 L 5,5 L 9,1"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.4"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          IsHitTestVisible="False" />
                                </Grid>
                            </Border>

                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,8,0,0"
                                        Padding="6"
                                        Background="{StaticResource PopupBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Popup" Property="MinHeight" Value="28" />
                            </Trigger>
                            <Trigger Property="Tag" Value="HideSelectionText">
                                <Setter TargetName="SelectionContent" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboSurface" Property="Background" Value="{StaticResource PopupItemHoverBrush}" />
                                <Setter TargetName="ComboSurface" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboSurface" Property="Background" Value="{StaticResource PopupItemSelectedBrush}" />
                                <Setter TargetName="ComboSurface" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource InlineComboStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="ComposerTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource PanelTextBoxStyle}">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="8,8,0,8"
                Padding="8,10"
                Width="{Binding SidebarWidth}"
                Background="{StaticResource PanelBrushSoft}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Button Width="32"
                            Height="32"
                            HorizontalAlignment="Left"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="{Binding Localization.HistoryTooltip}"
                            Command="{Binding ToggleHistoryPanelCommand}">
                        <Viewbox Width="14" Height="14">
                            <Path Data="{StaticResource HistoryIcon}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="0"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Viewbox>
                    </Button>
                    <Button Width="32"
                            Height="32"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="{Binding Localization.SettingsTooltip}"
                            Command="{Binding ToggleSettingsPanelCommand}">
                        <Viewbox Width="14" Height="14">
                            <Path Data="{StaticResource SettingsIcon}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,14,0,0"
                      Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Padding="10"
                            Background="Transparent"
                            Visibility="{Binding ShowHistoryPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding Localization.TopicsTitle}" />
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Content="{Binding Localization.NewTopicButton}"
                                        Command="{Binding NewThreadCommand}" />
                            </DockPanel>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Threads}"
                                     SelectedItem="{Binding SelectedThread}"
                                     ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextSecondaryBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,4,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11"
                                                       Text="{Binding Subtitle}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="2"
                                        Margin="0,10,0,0"
                                        Orientation="Horizontal">
                                <TextBox Width="186"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Text="{Binding RenameThreadName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding Localization.RenameTopicPlaceholder}" />
                                <Button Margin="8,0,0,0"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Content="{Binding Localization.RenameTopicButton}"
                                        Command="{Binding RenameThreadCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Padding="10"
                            Background="Transparent"
                            Visibility="{Binding ShowSettingsPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,10"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding Localization.SettingsTitle}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.ExecutableLabel}" />
                                <TextBox Margin="0,0,0,10"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Text="{Binding Settings.CodexExecutablePath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.WorkingDirectoryLabel}" />
                                <TextBox Margin="0,0,0,10"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Text="{Binding Settings.WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.VerbosityLabel}" />
                                <ComboBox Margin="0,0,0,10"
                                          Style="{StaticResource PanelComboBoxStyle}"
                                          ItemsSource="{Binding VerbosityOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedVerbosity, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.ApprovalPolicyLabel}" />
                                <ComboBox Margin="0,0,0,10"
                                          Style="{StaticResource PanelComboBoxStyle}"
                                          ItemsSource="{Binding ApprovalPolicyOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedApprovalPolicy, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.RawOutputLabel}" />
                                <TextBox Style="{StaticResource PanelTextBoxStyle}"
                                         MinHeight="140"
                                         FontFamily="Consolas"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding Output}" />

                                <TextBlock Margin="0,12,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.AppsTitle}" />
                                <ItemsControl ItemsSource="{Binding Apps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="{Binding Name}" />
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Margin="0,12,0,4"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding Localization.McpServersTitle}" />
                                <ItemsControl ItemsSource="{Binding McpServers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="{Binding Name}" />
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Text="{Binding AuthStatus}" />
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Text="{Binding ToolsLabel}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Button Grid.Column="1"
                Panel.ZIndex="10"
                Width="36"
                Height="28"
                Margin="14,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Command="{Binding ToggleHistoryPanelCommand}">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource TopIconButtonStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Viewbox Width="14" Height="14">
                <Path Data="{StaticResource BarsIcon}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Stretch="Uniform" />
            </Viewbox>
        </Button>

        <Grid Grid.Column="1" Margin="14,10,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="Bubble"
                                            MaxWidth="540"
                                            Margin="0,0,0,26"
                                            Padding="0"
                                            HorizontalAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0">
                                        <StackPanel>
                                            <TextBlock x:Name="EventTitle"
                                                       Margin="0,0,0,8"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       Visibility="Collapsed" />
                                            <TextBlock x:Name="BubbleText"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13"
                                                       LineHeight="20"
                                                       Text="{Binding Text}"
                                                       TextWrapping="Wrap" />
                                            <Border x:Name="EventDetailHost"
                                                    Margin="0,10,0,0"
                                                    Padding="10,8"
                                                    Background="{StaticResource EventDetailBrush}"
                                                    BorderBrush="{StaticResource PanelBorderSoftBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Visibility="Collapsed">
                                                <TextBlock x:Name="EventDetailText"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           LineHeight="17"
                                                           Text="{Binding Detail}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasTitle}" Value="True">
                                            <Setter TargetName="EventTitle" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                            <Setter TargetName="EventDetailHost" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                            <Setter TargetName="Bubble" Property="Background" Value="{StaticResource UserBubbleBrush}" />
                                            <Setter TargetName="Bubble" Property="Padding" Value="14,11" />
                                            <Setter TargetName="Bubble" Property="CornerRadius" Value="16" />
                                            <Setter TargetName="Bubble" Property="Margin" Value="0,0,8,26" />
                                            <Setter TargetName="BubbleText" Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsUser}" Value="False">
                                            <Setter TargetName="Bubble" Property="Margin" Value="34,34,96,26" />
                                            <Setter TargetName="BubbleText" Property="FontSize" Value="14" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEvent}" Value="True">
                                            <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter TargetName="Bubble" Property="MaxWidth" Value="680" />
                                            <Setter TargetName="Bubble" Property="Background" Value="{StaticResource EventCardBrush}" />
                                            <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource EventCardBorderBrush}" />
                                            <Setter TargetName="Bubble" Property="BorderThickness" Value="1" />
                                            <Setter TargetName="Bubble" Property="Padding" Value="14,12" />
                                            <Setter TargetName="Bubble" Property="CornerRadius" Value="14" />
                                            <Setter TargetName="Bubble" Property="Margin" Value="34,4,96,18" />
                                            <Setter TargetName="BubbleText" Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                            <Setter TargetName="BubbleText" Property="FontSize" Value="12" />
                                            <Setter TargetName="BubbleText" Property="LineHeight" Value="18" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Margin="34,34,96,26"
                                Padding="14,12"
                                HorizontalAlignment="Left"
                                Background="{StaticResource EventCardBrush}"
                                BorderBrush="{StaticResource EventCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Margin="0,0,6,0"
                                         Fill="{StaticResource TextSecondaryBrush}"
                                         Opacity="0.28">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.18" Value="1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.54" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.9" Value="0.28" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="8"
                                         Height="8"
                                         Margin="0,0,6,0"
                                         Fill="{StaticResource TextSecondaryBrush}"
                                         Opacity="0.28">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.18" Value="0.28" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.36" Value="1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.72" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.9" Value="0.28" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{StaticResource TextSecondaryBrush}"
                                         Opacity="0.28">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.36" Value="0.28" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.54" Value="1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="0.28" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1"
                        Margin="0,0,0,8"
                        Padding="10"
                        Background="{StaticResource PanelBrushSoft}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding HasMentionSuggestions, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox ItemsSource="{Binding MentionSuggestions}"
                                 SelectedItem="{Binding SelectedMention}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextSecondaryBrush}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource MiniButtonStyle}"
                                Content="{Binding Localization.InsertButton}"
                                Command="{Binding InsertSelectedMentionCommand}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Padding="0"
                    Background="{StaticResource InputBrush}"
                    BorderBrush="{StaticResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="16,14,16,2">
                        <TextBox x:Name="PromptTextBox"
                                 Style="{StaticResource ComposerTextBoxStyle}"
                                 MinHeight="66"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,70,0"
                                   VerticalAlignment="Top"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   IsHitTestVisible="False"
                                   Text="{Binding Localization.ComposerPlaceholder}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=PromptTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Grid.Row="1" Margin="16,10,16,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <WrapPanel Margin="0,0,12,0"
                                   Orientation="Horizontal">
                            <Button Width="32"
                                    Height="32"
                                    Margin="0,0,8,8"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="{Binding Localization.AddAttachmentTooltip}"
                                    Command="{Binding AddImageFileCommand}">
                                <Viewbox Width="14" Height="14">
                                    <Path Data="{StaticResource PaperclipIcon}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                            <Border MinHeight="32"
                                    Margin="0,0,8,8"
                                    Background="{StaticResource ChipBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="14">
                                <Grid>
                                    <ComboBox MinWidth="150"
                                              Tag="HideSelectionText"
                                              Padding="34,0,14,0"
                                              Style="{StaticResource InlineComboStyle}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              ItemsSource="{Binding ModelOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="34,0,32,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               IsHitTestVisible="False"
                                               Text="{Binding SelectedModelLabel}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Viewbox Width="12"
                                             Height="12"
                                             Margin="12,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             IsHitTestVisible="False">
                                        <Path Data="{StaticResource BoltIcon}"
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                </Grid>
                            </Border>
                            <Border MinHeight="32"
                                    Margin="0,0,8,8"
                                    Background="{StaticResource ChipBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="14">
                                <Grid>
                                    <ComboBox Width="112"
                                              Tag="HideSelectionText"
                                              Padding="10,0,14,0"
                                              Style="{StaticResource InlineComboStyle}"
                                              ItemsSource="{Binding ReasoningOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedReasoningEffort, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="10,0,28,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               IsHitTestVisible="False"
                                               Text="{Binding SelectedReasoningEffortLabel}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </WrapPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                            <Button Margin="0,0,0,8"
                                    Style="{StaticResource SendButtonStyle}"
                                    ToolTip="{Binding Localization.SendTooltip}"
                                    Command="{Binding SendCommand}">
                                <Viewbox Width="14" Height="14">
                                    <Path Data="{StaticResource SendIcon}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ItemsControl Grid.Row="2"
                                  Margin="16,0,16,8"
                                  ItemsSource="{Binding AttachedImages}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AttachedImages.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="AttachmentCard"
                                      Width="156"
                                      Height="104"
                                      Margin="0,0,8,8"
                                      ToolTip="{Binding}">
                                    <Border x:Name="AttachmentBorder"
                                            Background="{StaticResource ChipBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <Grid ClipToBounds="True">
                                            <Image Source="{Binding}"
                                                   Stretch="UniformToFill" />
                                            <Border x:Name="AttachmentHoverMask"
                                                    Background="#00000000" />
                                            <Border Background="#CC101216" VerticalAlignment="Bottom">
                                                <TextBlock Margin="10,8"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="11"
                                                           Text="{Binding Converter={StaticResource PathToFileNameConverter}}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <Button x:Name="AttachmentRemoveButton"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="8"
                                            Visibility="Collapsed"
                                            Style="{StaticResource AttachmentRemoveButtonStyle}"
                                            ToolTip="{Binding DataContext.Localization.RemoveAttachmentHoverLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Command="{Binding DataContext.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Viewbox Width="10" Height="10">
                                            <Path Data="{StaticResource CloseIcon}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                    </Button>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="AttachmentCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="AttachmentBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="AttachmentBorder" Property="BorderThickness" Value="1.5" />
                                        <Setter TargetName="AttachmentHoverMask" Property="Background" Value="#1AFFFFFF" />
                                        <Setter TargetName="AttachmentRemoveButton" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="3" Margin="0,2,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Height="1"
                                Background="{StaticResource PanelBorderSoftBrush}" />

                        <Grid Grid.Row="1" Margin="16,10,16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <WrapPanel Margin="0,0,12,0"
                                       Orientation="Horizontal">
                                <Border Margin="0,0,8,8"
                                        Padding="10,6"
                                        Background="{StaticResource ChipBrush}"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="14">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                            <Path Data="{StaticResource FolderIcon}"
                                                  Fill="{StaticResource TextPrimaryBrush}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding Localization.LocalButton}" />
                                    </StackPanel>
                                </Border>
                                <ToggleButton Margin="0,0,8,8"
                                              Style="{StaticResource ChipToggleButtonStyle}"
                                              IsChecked="{Binding PlanModeEnabled, UpdateSourceTrigger=PropertyChanged}">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                            <Path Data="{StaticResource BoltIcon}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding CollaborationModeLabel}" />
                                    </StackPanel>
                                </ToggleButton>
                                <Border MinHeight="32"
                                        Margin="0,0,8,8"
                                        Padding="0"
                                        Background="{StaticResource ChipBrush}"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="14">
                                    <Grid>
                                        <ComboBox MinWidth="152"
                                                  Tag="HideSelectionText"
                                                  Padding="34,0,14,0"
                                                  Style="{StaticResource InlineComboStyle}"
                                                  Foreground="{StaticResource AccentBrush}"
                                                  ItemsSource="{Binding SandboxModeOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding SelectedSandboxMode, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="34,0,32,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   IsHitTestVisible="False"
                                                   Text="{Binding SelectedSandboxModeLabel}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Viewbox Width="12"
                                                 Height="12"
                                                 Margin="12,0,0,0"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 IsHitTestVisible="False">
                                            <Path Data="{StaticResource ShieldIcon}"
                                                  Fill="{StaticResource AccentBrush}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                    </Grid>
                                </Border>
                            </WrapPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top">
                                <Border Width="18"
                                        Height="18"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="{StaticResource ChipBrush}">
                                    <Path Data="{Binding ContextRingGeometry}"
                                          Margin="2"
                                          Stretch="Fill"
                                          Stroke="{StaticResource SuccessBrush}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Border>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10"
                                           Text="{Binding ContextTokensLabel}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.ColumnSpan="2"
                Panel.ZIndex="40"
                Background="#8C0B0D10"
                Visibility="{Binding HasCurrentApprovalPrompt, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Border Width="460"
                        Padding="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource PopupBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel DataContext="{Binding CurrentApprovalPrompt}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34"
                                    Height="34"
                                    Margin="0,0,12,0"
                                    Background="#26F59E0B"
                                    CornerRadius="17">
                                <Viewbox Margin="9">
                                    <Path Data="{StaticResource WarningIcon}"
                                          Fill="#F59E0B"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Border>
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="{Binding Title}" />
                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"
                                           Text="{Binding Subtitle}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Subtitle, TargetNullValue=''}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ApprovalCommandBlock" Margin="0,16,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Command, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalCommandLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBox Margin="0,4,0,0"
                                     Style="{StaticResource PanelTextBoxStyle}"
                                     FontFamily="Consolas"
                                     IsReadOnly="True"
                                     Text="{Binding Command}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ApprovalReasonBlock" Margin="0,12,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Reason, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalReasonLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding Reason}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ApprovalDirectoryBlock" Margin="0,12,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkingDirectory, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalWorkingDirectoryLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       Text="{Binding WorkingDirectory}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ApprovalGrantRootBlock" Margin="0,12,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GrantRoot, TargetNullValue=''}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Text="{Binding DataContext.Localization.ApprovalGrantRootLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       Text="{Binding GrantRoot}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ItemsControl Margin="0,18,0,0"
                                      ItemsSource="{Binding Options}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,10,10"
                                            Command="{Binding DataContext.ResolveApprovalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ApprovalActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPrimary}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SendButtonBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDanger}" Value="True">
                                                        <Setter Property="Background" Value="#26EF4444" />
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Label}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.ColumnSpan="2"
                Panel.ZIndex="41"
                Background="#8C0B0D10"
                Visibility="{Binding HasCurrentUserInputPrompt, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Border Width="460"
                        Padding="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource PopupBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel DataContext="{Binding CurrentUserInputPrompt}">
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="{Binding Title}" />

                        <ItemsControl Margin="0,16,0,0"
                                      ItemsSource="{Binding Questions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   Text="{Binding Header}" />
                                        <TextBlock Margin="0,4,0,8"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding Question}"
                                                   TextWrapping="Wrap" />
                                        <ComboBox ItemsSource="{Binding Options}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding SelectedOptionValue, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox" BasedOn="{StaticResource PanelComboBoxStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AcceptsText}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                        </ComboBox>
                                        <TextBox Text="{Binding AnswerText, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource PanelTextBoxStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AcceptsText}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Margin="0,0,10,0"
                                    Style="{StaticResource ApprovalActionButtonStyle}"
                                    Content="{Binding DataContext.Localization.ApprovalCancel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <Button Style="{StaticResource ApprovalActionButtonStyle}"
                                    Background="{StaticResource SendButtonBrush}"
                                    Content="{Binding DataContext.Localization.InsertButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Command="{Binding DataContext.ResolveUserInputCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
